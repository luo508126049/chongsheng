# Server
PORT=5174
CLIENT_ORIGIN=http://localhost:5173

# MySQL for Prisma. Keep DATA_STORE=memory for local prototype work.
DATA_STORE=memory
DATABASE_URL="mysql://user:password@localhost:3306/rebirth_billion_times"

# DeepSeek-compatible API. If omitted, the server uses deterministic fallback story output.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Client
VITE_API_BASE=
